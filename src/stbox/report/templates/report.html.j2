<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>stbox scan — {{ r.target }}</title>
<style>
  :root {
    --bg: #0b0f14;
    --panel: #121821;
    --panel-2: #182231;
    --border: #263243;
    --text: #e7ecf3;
    --muted: #8ea0b5;
    --accent: #4ec9b0;
    --critical: #ff4d6d;
    --high: #ff8c42;
    --medium: #f1c40f;
    --low: #2ecc71;
    --info: #3498db;
  }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--text); font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; font-size: 14px; line-height: 1.5; }
  header { padding: 32px 48px; background: linear-gradient(135deg, #0a1423, #152a3d); border-bottom: 1px solid var(--border); }
  header h1 { margin: 0 0 8px 0; font-size: 28px; color: var(--accent); }
  header .target { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 18px; word-break: break-all; }
  header .meta { color: var(--muted); margin-top: 8px; font-size: 13px; }
  main { padding: 32px 48px; max-width: 1200px; margin: 0 auto; }
  section { margin-bottom: 32px; }
  h2 { color: var(--accent); border-bottom: 1px solid var(--border); padding-bottom: 8px; margin-top: 0; }
  .summary { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 24px; }
  .card { background: var(--panel); border: 1px solid var(--border); border-radius: 8px; padding: 16px; text-align: center; }
  .card .count { font-size: 28px; font-weight: bold; margin-bottom: 4px; }
  .card .label { color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; }
  .card.critical { border-color: var(--critical); }
  .card.critical .count { color: var(--critical); }
  .card.high { border-color: var(--high); }
  .card.high .count { color: var(--high); }
  .card.medium { border-color: var(--medium); }
  .card.medium .count { color: var(--medium); }
  .card.low { border-color: var(--low); }
  .card.low .count { color: var(--low); }
  .card.info { border-color: var(--info); }
  .card.info .count { color: var(--info); }
  .finding { background: var(--panel); border-left: 4px solid var(--info); border-radius: 4px; padding: 16px 20px; margin-bottom: 8px; }
  .finding.critical { border-left-color: var(--critical); }
  .finding.high { border-left-color: var(--high); }
  .finding.medium { border-left-color: var(--medium); }
  .finding.low { border-left-color: var(--low); }
  .finding.info { border-left-color: var(--info); }
  .finding h3 { margin: 0 0 8px 0; font-size: 16px; }
  .finding .meta { color: var(--muted); font-size: 12px; margin-bottom: 8px; }
  .finding .tag { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 11px; background: var(--panel-2); margin-right: 4px; }
  .badge { display: inline-block; padding: 2px 10px; border-radius: 4px; font-weight: bold; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; margin-right: 8px; }
  .badge.critical { background: var(--critical); color: white; }
  .badge.high { background: var(--high); color: white; }
  .badge.medium { background: var(--medium); color: #1a1a1a; }
  .badge.low { background: var(--low); color: white; }
  .badge.info { background: var(--info); color: white; }
  .evidence { background: var(--panel-2); padding: 12px; border-radius: 4px; margin-top: 8px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; overflow-x: auto; color: var(--muted); white-space: pre-wrap; word-break: break-word; }
  .cve { color: var(--critical); font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; }
  table { width: 100%; border-collapse: collapse; background: var(--panel); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  th, td { padding: 10px 14px; border-bottom: 1px solid var(--border); text-align: left; }
  th { background: var(--panel-2); color: var(--accent); font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; }
  code { background: var(--panel-2); padding: 1px 6px; border-radius: 3px; font-size: 12px; }
  .note { background: #3a2f12; border-left: 4px solid var(--medium); padding: 12px 16px; border-radius: 4px; color: #ffe49a; }
  .perm { background: #3a1212; border-left: 4px solid var(--critical); padding: 12px 16px; border-radius: 4px; color: #ffb3b3; }
  footer { padding: 24px 48px; color: var(--muted); font-size: 12px; text-align: center; border-top: 1px solid var(--border); }
  details summary { cursor: pointer; color: var(--accent); user-select: none; }
</style>
</head>
<body>
<header>
  <h1>stbox — Security Scan Report</h1>
  <div class="target">{{ r.target }}</div>
  <div class="meta">
    Mode: <strong>{{ r.mode.value }}</strong> ·
    Started: {{ r.started_at.strftime("%Y-%m-%d %H:%M UTC") }}
    {% if r.finished_at %} · Finished: {{ r.finished_at.strftime("%Y-%m-%d %H:%M UTC") }}{% endif %}
    · {{ findings | length }} findings
  </div>
</header>

<main>

{% if r.mode.value == "active" and r.permission_ack %}
  <section><div class="perm">
    ⚠ Active scan — confirmed via --i-have-permission. This scan injected payloads and may trigger IDS/IPS.
  </div></section>
{% endif %}

{% if r.scope_notes %}
  <section><div class="note">
    <strong>Scope notes:</strong>
    <ul>{% for n in r.scope_notes %}<li>{{ n }}</li>{% endfor %}</ul>
  </div></section>
{% endif %}

<section>
  <h2>Summary</h2>
  <div class="summary">
    <div class="card critical"><div class="count">{{ counts.critical }}</div><div class="label">Critical</div></div>
    <div class="card high"><div class="count">{{ counts.high }}</div><div class="label">High</div></div>
    <div class="card medium"><div class="count">{{ counts.medium }}</div><div class="label">Medium</div></div>
    <div class="card low"><div class="count">{{ counts.low }}</div><div class="label">Low</div></div>
    <div class="card info"><div class="count">{{ counts.info }}</div><div class="label">Info</div></div>
  </div>
</section>

{% if r.subdomains %}
<section>
  <h2>Subdomains ({{ r.subdomains | length }})</h2>
  <details>
    <summary>Show all subdomains</summary>
    <div class="evidence">{% for s in r.subdomains %}{{ s }}{% if not loop.last %}
{% endif %}{% endfor %}</div>
  </details>
</section>
{% endif %}

{% if r.live_hosts %}
<section>
  <h2>Live hosts ({{ r.live_hosts | length }})</h2>
  <table>
    <thead><tr><th>Host</th><th>Tech stack</th></tr></thead>
    <tbody>
      {% for host in r.live_hosts %}
      <tr>
        <td><code>{{ host }}</code></td>
        <td>{% for t in r.tech_stack.get(host, []) %}<span class="tag">{{ t }}</span>{% endfor %}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</section>
{% endif %}

<section>
  <h2>Findings ({{ findings | length }})</h2>
  {% for f in findings %}
  <div class="finding {{ f.severity.value }}">
    <h3><span class="badge {{ f.severity.value }}">{{ f.severity.value }}</span>{{ f.title }}</h3>
    <div class="meta">
      <strong>{{ f.tool }}</strong> · target: <code>{{ f.target }}</code>
      {% for t in f.tags %}<span class="tag">{{ t }}</span>{% endfor %}
    </div>
    {% if f.cve %}<div class="cve">{{ f.cve | join(", ") }}</div>{% endif %}
    {% if f.description %}<p>{{ f.description }}</p>{% endif %}
    {% if f.evidence %}
      <details>
        <summary>Evidence</summary>
        <div class="evidence">{{ f.evidence | tojson(indent=2) }}</div>
      </details>
    {% endif %}
    {% if f.references %}
      <details>
        <summary>References ({{ f.references | length }})</summary>
        <div class="evidence">{% for ref in f.references %}{{ ref }}{% if not loop.last %}
{% endif %}{% endfor %}</div>
      </details>
    {% endif %}
  </div>
  {% else %}
  <p style="color: var(--muted)">No findings.</p>
  {% endfor %}
</section>

<section>
  <h2>Tool runs</h2>
  <table>
    <thead><tr><th>Tool</th><th>Status</th><th>Duration</th><th>Findings</th><th>Exit</th></tr></thead>
    <tbody>
      {% for t in r.tool_runs %}
      <tr>
        <td>{{ t.tool }}</td>
        <td>{{ t.status }}</td>
        <td>{% if t.duration_seconds %}{{ "%.1fs"|format(t.duration_seconds) }}{% else %}-{% endif %}</td>
        <td>{{ t.findings_count }}</td>
        <td>{{ t.exit_code }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</section>

</main>
<footer>
  Generated by <strong>stbox</strong> — <a href="https://github.com/JaviiHernandez/SecurityToolbox-CLI" style="color: var(--accent)">github.com/JaviiHernandez/SecurityToolbox-CLI</a>
</footer>
</body>
</html>
